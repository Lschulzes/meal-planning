{
  "name": "meal-planning",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @meal-planning/db db:push",
    "db:studio": "turbo -F @meal-planning/db db:studio",
    "db:generate": "turbo -F @meal-planning/db db:generate",
    "db:migrate": "turbo -F @meal-planning/db db:migrate",
    "db:start": "turbo -F @meal-planning/db db:start",
    "db:watch": "turbo -F @meal-planning/db db:watch",
    "db:stop": "turbo -F @meal-planning/db db:stop",
    "db:down": "turbo -F @meal-planning/db db:down",
    "db:seed": "turbo -F @meal-planning/db db:seed",
    "sync": "turbo -F server sync",
    "sync:enrich": "turbo -F server sync:enrich"
  },
  "dependencies": {
    "@meal-planning/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@meal-planning/config": "workspace:*",
    "@types/node": "catalog:",
    "turbo": "^2.8.12",
    "typescript": "^5"
  },
  "packageManager": "pnpm@10.14.0"
}
